<!-- Monochrome status-bar notification icon (brand double-chevron). Android
     draws it using the alpha channel only and tints it with
     default_notification_color, so the symbol is white on transparent. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M6,5 L13,12 L6,19" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M11,5 L18,12 L11,19" />
</vector>
